# Порт HTTP-сервера микросервиса
SERVER_PORT=8080

# Путь к публичному ключу RSA для проверки подписи JWT (относительно cmd/ или абсолютный)
JWT_PUBLIC_KEY_PATH=../config/jwt/public.pem

# Симметричный JWT-секрет Mercure Hub для публикации событий в реальном времени
MERCURE_JWT_SECRET=your_mercure_jwt_secret_here

# Подключение к RabbitMQ для синхронизации справочника пользователей (реплики users)
# Для запуска локально на хосте: amqp://guest:guest@localhost:5672/
# Для запуска в Docker-сети:   amqp://guest:guest@rabbitmq:5672/
RABBITMQ_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/

# Подключение к базе данных PostgreSQL (БД канбана)
DB_HOST=localhost
DB_PORT=5433
DB_USER=root
DB_PASSWORD=password
DB_NAME=kanban_db

KANBAN_DB_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable

# Конфигурация для утилиты goose (чтобы работала команда `goose up`)
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=${KANBAN_DB_URL}
GOOSE_MIGRATION_DIR=migrations
